{
  "name": "@commerce-klaus/babel-plugin-sfcc-modules",
  "version": "1.0.0",
  "description": "Babel plugin to handle non-standard module paths used by Salesforce Commerce Cloud (SFCC)",
  "keywords": [
    "babel",
    "babel-plugin",
    "cartridge",
    "commercecloud",
    "demandware",
    "import",
    "module",
    "require",
    "salesforce",
    "sfcc",
    "sfra",
    "supermodule"
  ],
  "homepage": "https://github.com/commerce-klaus/commerce-klaus/tree/main/packages/babel-plugin-sfcc-modules#readme",
  "bugs": {
    "url": "https://github.com/commerce-klaus/commerce-klaus/issues"
  },
  "license": "MIT",
  "author": "Jens Simon <https://github.com/jenssimon>",
  "repository": {
    "type": "git",
    "url": "https://github.com/commerce-klaus/commerce-klaus",
    "directory": "packages/babel-plugin-sfcc-modules"
  },
  "files": [
    "/dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@babel/types": "^7.29.0",
    "imports-visitor": "^2.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/register": "^7.28.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@11.9.0"
}
